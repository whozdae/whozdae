<#
.SYNOPSIS
    Ensures Kernel DMA Protection is enabled by blocking all external devices incompatible with DMA protection.

.NOTES
    Author          : Alex Adewoyin
    LinkedIn        : linkedin.com/in/alexadewoyin/
    GitHub          : github.com/whozdae
    Date Created    : 2026-03-15
    Version         : 1.0
    STIG-ID         : WN11-EP-000310
    Severity        : CAT II (Medium)

.TESTED ON
    Date(s) Tested  : 
    Tested By       : 
    Systems Tested  : 
    PowerShell Ver. : 

.USAGE
    Run with Administrative privileges.
    PS C:\> .\Remediate-WN11-EP-000310.ps1 
#>

# 1. Define STIG Registry Parameters
$registryPath = "HKLM:\Software\Policies\Microsoft\Windows\Kernel DMA Protection"
$valueName    = "DeviceEnumerationPolicy"
$valueData    = 0

# 2. Path Remediation: Ensure the Policy path exists
if (-not (Test-Path $registryPath)) {
    New-Item -Path $registryPath -Force | Out-Null
    Write-Host "CREATED: Registry path $registryPath."
}

# 3. Value Remediation: Enforce REG_DWORD = 0 (Block All)
$currentValue = Get-ItemProperty -Path $registryPath -Name $valueName -ErrorAction SilentlyContinue

if ($null -eq $currentValue -or $currentValue.$valueName -ne $valueData) {
    New-ItemProperty -Path $registryPath -Name $valueName -Value $valueData -PropertyType DWord -Force | Out-Null
    Write-Host "REMEDIATED: WN11-EP-000310 - $valueName set to $valueData (Block All)."
}
else {
    Write-Host "COMPLIANT: WN11-EP-000310 - $valueName is already configured to Block All."
}

# 4. Force Group Policy Update
Write-Host "Triggering Group Policy Update..." -ForegroundColor Cyan
gpupdate /force
