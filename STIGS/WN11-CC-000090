<#
.SYNOPSIS
    Ensures Group Policy objects are reprocessed even if they have not changed and forces an immediate refresh.

.NOTES
    Author          : Alex Adewoyin
    LinkedIn        : linkedin.com/in/alexadewoyin/
    GitHub          : github.com/whozdae
    Date Created    : 2026-03-13
    Version         : 1.1
    STIG-ID         : WN11-CC-000090
    Severity        : CAT II (Medium)

.TESTED ON
    Date(s) Tested  : 
    Tested By       : 
    Systems Tested  : 
    PowerShell Ver. : 

.USAGE
    Run with Administrative privileges.
    PS C:\> .\Remediate-WN11-CC-000090.ps1 
#>

# 1. Define STIG Registry Parameters
$registryPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\Group Policy\{35378EAC-683F-11D2-A89A-00C04FBBCFA2}"
$valueName    = "NoGPOListChanges"
$valueData    = 0

# 2. Path Remediation
if (-not (Test-Path $registryPath)) {
    New-Item -Path $registryPath -Force | Out-Null
    Write-Host "CREATED: Registry path $registryPath."
}

# 3. Value Remediation
$currentValue = Get-ItemProperty -Path $registryPath -Name $valueName -ErrorAction SilentlyContinue

if ($null -eq $currentValue -or $currentValue.$valueName -ne $valueData) {
    New-ItemProperty -Path $registryPath -Name $valueName -Value $valueData -PropertyType DWord -Force | Out-Null
    Write-Host "REMEDIATED: WN11-CC-000090 - $valueName set to $valueData."
    $remediateRefresh = $true
}
else {
    Write-Host "COMPLIANT: WN11-CC-000090 - $valueName is already configured as specified."
    $remediateRefresh = $false
}

# 4. Force Group Policy Update
Write-Host "Triggering Group Policy Update..." -ForegroundColor Cyan
gpupdate /force

if ($remediateRefresh) {
    Write-Host "Remediation and Policy Refresh Complete." -ForegroundColor Green
}
